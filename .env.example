# Tujuan: Template environment variable fase 0 untuk backend, frontend, storage, dan infrastruktur lokal.
# Caller: Developer lokal, Docker Compose, backend ElysiaJS, frontend SvelteKit.
# Dependensi: PostgreSQL, Redis, MinIO, JWT config, Vite config.
# Main Functions: Menyediakan nilai default development yang konsisten untuk bootstrap proyek.
# Side Effects: Menentukan koneksi DB/Redis/S3, port aplikasi, dan perilaku auth runtime.

NODE_ENV=development
APP_NAME="LMS Bimbel"
APP_URL=http://localhost:3000

BACKEND_PORT=3000
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

JWT_SECRET=ganti-dengan-string-random-64-karakter-minimum-di-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_bimbel
DATABASE_MAX_CONNECTIONS=20

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lms-bimbel
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_URL_TTL=3600

MAX_UPLOAD_SIZE_MB=50
ALLOWED_VIDEO_TYPES=video/mp4,video/webm
ALLOWED_DOC_TYPES=application/pdf
ALLOWED_PAYMENT_PROOF_TYPES=image/jpeg,image/png,image/webp,application/pdf
ALLOWED_MATERIAL_ASSET_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4,video/webm

MAX_TAB_SWITCH_WARNING=3
MAX_COPY_ATTEMPT_WARNING=3

RATE_LIMIT_LOGIN=10
RATE_LIMIT_API=100

VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000/ws
VITE_APP_NAME="LMS Bimbel"
