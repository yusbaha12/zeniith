{
  "name": "@lms-bimbel/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --target bun --outdir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/infrastructure/database/seeds/index.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@lms-bimbel/shared": "workspace:*",
    "bullmq": "^5.78.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "x-doc": {
    "tujuan": "Manifest backend fase 1 untuk ElysiaJS, auth, Drizzle, Redis, dan seeding dasar.",
    "caller": "Bun runtime, Docker backend image, developer lokal.",
    "dependensi": "elysia, drizzle, jose, redis, shared package.",
    "mainFunctions": "Menyediakan dependency dan script bootstrap backend serta seed auth/user core.",
    "sideEffects": "Menjalankan dev server, build, dan command database."
  }
}
