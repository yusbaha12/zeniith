# =============================================================================
# LMS Bimbel - Monorepo .gitignore
# Stack: Bun, SvelteKit (Frontend), ElysiaJS (Backend), Drizzle ORM, PostgreSQL
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables & Secrets — JANGAN PERNAH DI-COMMIT!
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Node Modules (semua workspace)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

# -----------------------------------------------------------------------------
# Bun
# -----------------------------------------------------------------------------
.bun/
bun.lock.bak

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
# Backend (ElysiaJS)
apps/backend/dist/

# Frontend (SvelteKit)
apps/frontend/.svelte-kit/
apps/frontend/build/
apps/frontend/.output/

# Package workspace builds
packages/**/dist/

# -----------------------------------------------------------------------------
# Database (Drizzle ORM)
# -----------------------------------------------------------------------------
# Jika migration di-generate dari schema local, exclude folder snapshot
# apps/backend/src/infrastructure/database/migrations/meta/
# Uncomment baris di atas jika tidak ingin migration file di-commit

# SQLite file (jika digunakan untuk test lokal)
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.iml
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
junit.xml
test-results/

# -----------------------------------------------------------------------------
# Frontend Artifacts (typecheck output, etc.)
# -----------------------------------------------------------------------------
apps/frontend/typecheck_output*.txt

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Uncomment jika ada data volume docker lokal
# docker/data/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
